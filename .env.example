# 复制为 .env 后填写本地值；不要将含真实密码的 .env 提交到 Git

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_DATABASE=english

# 若 PDD 库密码不同，可扩展 config/db.py 使用 PDD_DB_密码

# Chess 模块（独立数据库，缺省本机同账号 / 库名 chess）
CHESS_DB_HOST=localhost
CHESS_DB_USER=root
CHESS_DB_PASSWORD=
CHESS_DB_DATABASE=chess

# Chess 模块微信登录（小程序管理后台 -> 开发 -> 开发设置）
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 部署（deploy.sh 用，SSH 密码登录目标服务器）
DEPLOY_HOST=
DEPLOY_USER=root
DEPLOY_PASSWORD=
DEPLOY_PATH=
